import { useState } from 'react';
import { Sliders, Layers, Zap } from 'lucide-react';

interface AdvancedFeaturesProps {
  onApply?: (settings: any) => void;
}

export default function AdvancedFeatures({ onApply }: AdvancedFeaturesProps) {
  const [brightness, setBrightness] = useState(100);
  const [contrast, setContrast] = useState(100);
  const [saturation, setSaturation] = useState(100);
  const [sharpness, setSharpness] = useState(100);
  const [removeBackground, setRemoveBackground] = useState(false);

  const handleApply = () => {
    if (onApply) {
      onApply({
        brightness,
        contrast,
        saturation,
        sharpness,
        removeBackground,
      });
    }
  };

  const resetToDefault = () => {
    setBrightness(100);
    setContrast(100);
    setSaturation(100);
    setSharpness(100);
    setRemoveBackground(false);
  };

  return (
    <div className="bg-card border border-primary/30 rounded p-4 space-y-4">
      <h3 className="text-sm font-bold text-primary tracking-wider flex items-center gap-2">
        <Sliders className="w-4 h-4" />
        ADVANCED CONTROLS
      </h3>

      {/* Brightness */}
      <div>
        <div className="flex justify-between items-center mb-2">
          <label className="text-xs font-medium text-foreground">Brightness</label>
          <span className="text-xs text-muted-foreground">{brightness}%</span>
        </div>
        <input
          type="range"
          min="50"
          max="150"
          value={brightness}
          onChange={(e) => setBrightness(Number(e.target.value))}
          className="w-full cursor-pointer"
          style={{ accentColor: '#00d9ff' }}
        />
      </div>

      {/* Contrast */}
      <div>
        <div className="flex justify-between items-center mb-2">
          <label className="text-xs font-medium text-foreground">Contrast</label>
          <span className="text-xs text-muted-foreground">{contrast}%</span>
        </div>
        <input
          type="range"
          min="50"
          max="150"
          value={contrast}
          onChange={(e) => setContrast(Number(e.target.value))}
          className="w-full cursor-pointer"
          style={{ accentColor: '#00d9ff' }}
        />
      </div>

      {/* Saturation */}
      <div>
        <div className="flex justify-between items-center mb-2">
          <label className="text-xs font-medium text-foreground">Saturation</label>
          <span className="text-xs text-muted-foreground">{saturation}%</span>
        </div>
        <input
          type="range"
          min="0"
          max="150"
          value={saturation}
          onChange={(e) => setSaturation(Number(e.target.value))}
          className="w-full cursor-pointer"
          style={{ accentColor: '#00ff88' }}
        />
      </div>

      {/* Sharpness */}
      <div>
        <div className="flex justify-between items-center mb-2">
          <label className="text-xs font-medium text-foreground">Sharpness</label>
          <span className="text-xs text-muted-foreground">{sharpness}%</span>
        </div>
        <input
          type="range"
          min="0"
          max="150"
          value={sharpness}
          onChange={(e) => setSharpness(Number(e.target.value))}
          className="w-full cursor-pointer"
          style={{ accentColor: '#00d9ff' }}
        />
      </div>

      {/* Remove Background Toggle */}
      <div className="border-t border-primary/20 pt-4">
        <label className="flex items-center gap-3 cursor-pointer">
          <input
            type="checkbox"
            checked={removeBackground}
            onChange={(e) => setRemoveBackground(e.target.checked)}
            className="w-4 h-4 rounded border-primary cursor-pointer"
          />
          <span className="text-xs font-medium text-foreground flex items-center gap-1">
            <Layers className="w-3 h-3" />
            Remove Background
          </span>
        </label>
        <p className="text-xs text-muted-foreground mt-1 ml-7">
          Remove background while preserving subject
        </p>
      </div>

      {/* Action Buttons */}
      <div className="border-t border-primary/20 pt-4 space-y-2">
        <button
          onClick={handleApply}
          className="w-full btn-cyberpunk text-xs flex items-center justify-center gap-2"
        >
          <Zap className="w-4 h-4" />
          Apply Changes
        </button>
        <button
          onClick={resetToDefault}
          className="w-full px-3 py-2 text-xs border border-primary/30 text-foreground rounded hover:bg-primary/10 transition-colors"
        >
          Reset to Default
        </button>
      </div>
    </div>
  );
}
