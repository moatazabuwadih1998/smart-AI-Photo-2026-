import { X, Trash2 } from 'lucide-react';

interface HistoryItem {
  id: number;
  original: string;
  enhanced: string;
  device: string;
  category: string;
  style: string;
  timestamp: string;
}

interface HistoryPanelProps {
  history: HistoryItem[];
  onClose: () => void;
}

export default function HistoryPanel({ history, onClose }: HistoryPanelProps) {
  return (
    <div className="fixed inset-0 bg-black/80 flex items-center justify-center z-50 p-4">
      <div className="bg-card border border-primary/30 rounded max-w-2xl w-full max-h-96 overflow-y-auto">
        <div className="sticky top-0 bg-secondary/50 border-b border-primary/30 p-4 flex justify-between items-center">
          <h2 className="text-lg font-bold text-primary tracking-wider">HISTORY</h2>
          <button
            onClick={onClose}
            className="btn-cyberpunk p-2"
          >
            <X className="w-5 h-5" />
          </button>
        </div>

        <div className="p-4 space-y-3">
          {history.length === 0 ? (
            <p className="text-center text-muted-foreground py-8">No history yet</p>
          ) : (
            history.map((item) => (
              <div
                key={item.id}
                className="border border-primary/20 rounded p-3 hover:border-primary/50 transition-colors"
              >
                <div className="flex gap-3">
                  <img
                    src={item.enhanced}
                    alt="Enhanced"
                    className="w-16 h-16 object-cover rounded border border-primary/30"
                  />
                  <div className="flex-1 text-sm">
                    <p className="text-muted-foreground text-xs mb-1">{item.timestamp}</p>
                    <p className="text-foreground"><span className="text-primary">Device:</span> {item.device}</p>
                    <p className="text-foreground"><span className="text-primary">Category:</span> {item.category}</p>
                    <p className="text-foreground"><span className="text-primary">Style:</span> {item.style}</p>
                  </div>
                  <button
                    className="btn-cyberpunk p-2 h-fit"
                    title="Delete"
                  >
                    <Trash2 className="w-4 h-4" />
                  </button>
                </div>
              </div>
            ))
          )}
        </div>
      </div>
    </div>
  );
}
