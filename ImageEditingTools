import { useState } from 'react';
import { Crop, RotateCw, RotateCcw, Undo2, Redo2 } from 'lucide-react';

interface ImageEditingToolsProps {
  onCrop?: (cropData: any) => void;
  onRotate?: (angle: number) => void;
  onUndo?: () => void;
  onRedo?: () => void;
}

export default function ImageEditingTools({
  onCrop,
  onRotate,
  onUndo,
  onRedo,
}: ImageEditingToolsProps) {
  const [cropMode, setCropMode] = useState(false);
  const [rotation, setRotation] = useState(0);
  const [canUndo, setCanUndo] = useState(false);
  const [canRedo, setCanRedo] = useState(false);

  const handleRotateRight = () => {
    const newRotation = (rotation + 90) % 360;
    setRotation(newRotation);
    if (onRotate) {
      onRotate(newRotation);
    }
  };

  const handleRotateLeft = () => {
    const newRotation = (rotation - 90 + 360) % 360;
    setRotation(newRotation);
    if (onRotate) {
      onRotate(newRotation);
    }
  };

  const handleUndo = () => {
    if (onUndo) {
      onUndo();
      setCanRedo(true);
    }
  };

  const handleRedo = () => {
    if (onRedo) {
      onRedo();
      setCanUndo(true);
    }
  };

  return (
    <div className="bg-card border border-primary/30 rounded p-4 space-y-4">
      <h3 className="text-sm font-bold text-primary tracking-wider flex items-center gap-2">
        <Crop className="w-4 h-4" />
        EDITING TOOLS
      </h3>

      {/* Rotation Controls */}
      <div>
        <p className="text-xs font-medium text-foreground mb-2">Rotation: {rotation}°</p>
        <div className="flex gap-2">
          <button
            onClick={handleRotateLeft}
            className="flex-1 btn-cyberpunk text-xs flex items-center justify-center gap-1"
          >
            <RotateCcw className="w-4 h-4" />
            Left
          </button>
          <button
            onClick={handleRotateRight}
            className="flex-1 btn-cyberpunk text-xs flex items-center justify-center gap-1"
          >
            <RotateCw className="w-4 h-4" />
            Right
          </button>
        </div>
      </div>

      {/* Crop Mode Toggle */}
      <div>
        <button
          onClick={() => setCropMode(!cropMode)}
          className={`w-full text-xs py-2 px-3 rounded border-2 transition-all ${
            cropMode
              ? 'border-accent bg-accent/20 text-accent'
              : 'border-primary/30 text-foreground hover:border-primary/50'
          }`}
        >
          <Crop className="w-4 h-4 inline mr-2" />
          {cropMode ? 'Crop Mode: ON' : 'Crop Mode: OFF'}
        </button>
        <p className="text-xs text-muted-foreground mt-1">
          {cropMode ? 'Click and drag to crop' : 'Enable crop mode to edit'}
        </p>
      </div>

      {/* Undo/Redo Controls */}
      <div className="border-t border-primary/20 pt-4">
        <p className="text-xs font-medium text-foreground mb-2">History</p>
        <div className="flex gap-2">
          <button
            onClick={handleUndo}
            disabled={!canUndo}
            className="flex-1 btn-cyberpunk text-xs flex items-center justify-center gap-1 disabled:opacity-50"
          >
            <Undo2 className="w-4 h-4" />
            Undo
          </button>
          <button
            onClick={handleRedo}
            disabled={!canRedo}
            className="flex-1 btn-cyberpunk text-xs flex items-center justify-center gap-1 disabled:opacity-50"
          >
            <Redo2 className="w-4 h-4" />
            Redo
          </button>
        </div>
      </div>

      {/* Reset */}
      <button
        onClick={() => {
          setRotation(0);
          setCropMode(false);
        }}
        className="w-full px-3 py-2 text-xs border border-primary/30 text-foreground rounded hover:bg-primary/10 transition-colors"
      >
        Reset All
      </button>
    </div>
  );
}
